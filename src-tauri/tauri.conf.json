{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "unmarkdown",
  "version": "0.1.0",
  "identifier": "com.unmarkdown.editor",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Unmarkdown",
        "width": 1024,
        "height": 768,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["dmg"],
    "icon": [
      "icons/icon.icns"
    ],
    "macOS": {
      "minimumSystemVersion": "10.13"
    }
  }
}
